        "# Load the embedding model (bi-encoder)\n",
        "embed_model = SentenceTransformer(\"sentence-transformers/all-MiniLM-L6-v2\", device=DEVICE)\n",
        "\n",
        "# Create embeddings for all chunks\n",
        "# normalize_embeddings=True is important for cosine similarity\n",
        "print(\"Embedding all chunks (this may take 30-60 seconds)...\")\n",
        "embeddings = embed_model.encode(\n",
        "    [d[\"text\"] for d in docs],\n",
        "    convert_to_numpy=True,\n",
        "    normalize_embeddings=True,\n",
        "    show_progress_bar=True\n",
        ")\n",
        "\n",
        "# Build FAISS index\n",
        "dimension = embeddings.shape[1]  # 384 for all-MiniLM-L6-v2\n",
        "index = faiss.IndexFlatIP(dimension)  # Inner Product (equivalent to cosine with normalized vectors)\n",
        "index.add(embeddings)\n",
        "\n",
        "print(f\"✅ FAISS index created with {index.ntotal} vectors.\")"
      ]
    },
