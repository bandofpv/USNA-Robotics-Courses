      "source": [
        "# --- YOUR DESIGN DECISION ---\n",
        "# TODO: Choose your retrieval parameters\n",
        "MY_TOP_K      = 3   # TODO: Set a value (e.g., 2, 3, 5)\n",
        "MY_USE_RERANK = True   # TODO: Set True or False\n",
        "MY_SYNTHESIS_K = 6  # TODO: Set a value (e.g., 4, 6, 8)\n",
        "# ----------------------------\n",
        "\n",
        "# Load the re-ranker model (cross-encoder)\n",
        "reranker = None\n",
        "if MY_USE_RERANK:\n",
        "    try:\n",
        "        # Note: Downloading the re-ranker can take a minute\n",
        "        reranker = CrossEncoder(\"cross-encoder/ms-marco-MiniLM-L-6-v2\", device=DEVICE)\n",
        "        print(\"✅ Cross-encoder re-ranker loaded.\")\n",
        "    except Exception as e:\n",
        "        print(f\"⚠️ Could not load re-ranker, will disable. Error: {e}\")\n",
        "        MY_USE_RERANK = False\n",
        "\n",
        "def retrieve(query:str, top_k:int=MY_TOP_K, use_rerank:bool=MY_USE_RERANK):\n",
        "    # Set candidate K based on whether we will re-rank\n",
        "    candidate_k = top_k * 4 if use_rerank and reranker else top_k\n",
        "\n",
        "    # Stage 1: Fast retrieval from FAISS\n",
        "    qv = embed_model.encode([query], convert_to_numpy=True, normalize_embeddings=True)\n",
        "    D, I = index.search(qv, candidate_k)\n",
        "\n",
        "    # Guard clause for no results\n",
        "    if I.size == 0:\n",
        "        return []\n",
        "\n",
        "    candidates = [docs[i] for i in I[0]]\n",
        "\n",
        "    if not use_rerank or not reranker:\n",
        "        return candidates[:top_k] # No re-ranking, just return top K\n",
        "\n",
        "    # Stage 2: Precise re-ranking\n",
        "    try:\n",
        "        print(\"Re-ranking retrieved chunks...\")\n",
        "        scores = reranker.predict([(query, c[\"text\"]) for c in candidates])\n",
        "        # Sort by new scores and return the *new* top_k\n",
        "        order = np.argsort(scores)[::-1][:top_k]\n",
        "        return [candidates[o] for o in order]\n",
        "    except Exception as e:\n",
        "        print(f\"⚠️ Re-rank failed, falling back to bi-encoder. Error: {e}\")\n",
        "        return candidates[:top_k]\n",
        "\n",
        "# Test the retriever\n",
        "print(\"\\n--- Testing Retriever ---\")\n",
        "test_chunks = retrieve(\"logistics delays\")\n",
        "for i, chunk in enumerate(test_chunks):\n",
        "    print(f\"Rank {i+1} (Source: {chunk['doc']}): {chunk['text'][:100]}...\")"
      ]
