      "source": [
        "### Task 7.3: Implement the Generation Function"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 12,
      "metadata": {
        "id": "Tf_MIFYmuVBi",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "1e443398-422a-42da-895d-1a27bade3113"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "\n",
            "--- Testing Full RAG Pipeline ---\n",
            "Re-ranking retrieved chunks...\n",
            "Q: What were the main logistics issues?\n",
            "A: 1. Forklift shortage at FARP reduced ammunition and supply upload capacity by 40% and created a 6-hour backlog (Source: AAR_20.txt).\n",
            "2. Fuel resupply delays created critical shortages for two vehicles (Source: AAR_15.txt).\n",
            "3. Primary resupply route was blocked, forcing all logistics through a single...\n",
            "   Used 3 chunks\n"
          ]
        }
      ],
      "source": [
        "def ask(question:str, top_k:int=MY_TOP_K):\n",
        "    \"\"\"\n",
        "    Main RAG function: Retrieve relevant chunks, generate answer with citations.\n",
        "    \"\"\"\n",
        "    # Retrieve relevant contexts\n",
        "    contexts = retrieve(question, top_k=top_k, use_rerank=MY_USE_RERANK)\n",
        "\n",
        "    if not contexts:\n",
        "        return \"No relevant information found.\", []\n",
        "\n",
        "    # Format context for prompt\n",
        "    context_text = \"\\n\\n\".join([\n",
        "        f\"[{c['doc']}]\\n{c['text']}\"\n",
        "        for c in contexts\n",
        "    ])\n",
        "\n",
        "    # Generate answer based on available tier\n",
        "    if pipe_gpu:\n",
        "        # TIER 1: GPU Model\n",
        "        full_prompt = f\"{SYSTEM_PROMPT}\\n\\n{USER_PROMPT_TEMPLATE.format(context=context_text, question=question)}\"\n",
        "\n",
        "        inputs = tokenizer_gpu(full_prompt, return_tensors=\"pt\").to(DEVICE)\n",
        "        outputs = model_gpu.generate(\n",
        "            **inputs,\n",
        "            max_new_tokens=300,\n",
        "            temperature=0.3,\n",
        "            do_sample=True,\n",
        "            pad_token_id=tokenizer_gpu.eos_token_id\n",
        "        )\n",
        "\n",
        "        response = tokenizer_gpu.decode(outputs[0], skip_special_tokens=True)\n",
        "        # Extract only the generated part (after the prompt)\n",
        "        if \"Answer (with citations):\" in response:\n",
        "            answer = response.split(\"Answer (with citations):\")[-1].strip()\n",
        "        else:\n",
        "            answer = response[len(full_prompt):].strip()\n",
        "\n",
        "    elif pipe_cpu:\n",
        "        # TIER 2: CPU Model\n",
        "        full_prompt = f\"{SYSTEM_PROMPT}\\n\\n{USER_PROMPT_TEMPLATE.format(context=context_text, question=question)}\"\n",
        "\n",
        "        inputs = tokenizer_cpu(full_prompt, return_tensors=\"pt\", max_length=1024, truncation=True)\n",
        "        outputs = model_cpu.generate(\n",
        "            **inputs,\n",
        "            max_new_tokens=200,\n",
        "            temperature=0.3,\n",
        "            do_sample=True\n",
        "        )\n",
        "\n",
        "        answer = tokenizer_cpu.decode(outputs[0], skip_special_tokens=True)\n",
        "\n",
        "    else:\n",
        "        # TIER 3: Template Composer\n",
        "        # Simple concatenation with source labels\n",
        "        answer = \"Based on the provided AARs:\\n\\n\"\n",
        "        for c in contexts[:3]:\n",
        "            answer += f\"- {c['doc']}: {c['text'][:200]}...\\n\\n\"\n",
        "        answer += f\"\\nNote: This is a template-based response. For full LLM analysis, enable GPU or CPU model.\"\n",
        "\n",
        "    return answer, contexts\n",
        "\n",
        "# Test the system\n",
        "print(\"\\n--- Testing Full RAG Pipeline ---\")\n",
        "test_q = \"What were the main logistics issues?\"\n",
        "test_answer, test_contexts = ask(test_q)\n",
        "print(f\"Q: {test_q}\")\n",
        "print(f\"A: {test_answer[:300]}...\")\n",
        "print(f\"   Used {len(test_contexts)} chunks\")"
      ]
