      "source": [
        "## 8. 🔬 Part 5: Quantitative Evaluation & Tuning\n",
        "\n",
        "Now we evaluate your design choices with an automated scoring harness.\n",
        "\n",
        "### Task 8.1: Define Evaluation Harness\n",
        "\n",
        "This harness tests 6 queries covering:\n",
        "* **Aggregate questions** (Q1, Q2): Require sampling across multiple AARs\n",
        "* **Specific questions** (Q3, Q4): Target precise information\n",
        "* **Hallucination test** (Q5): Should refuse when evidence is absent\n",
        "* **Synthesis** (Q6): Identify multiple patterns across corpus"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 13,
      "metadata": {
        "id": "EXvcmLaLuVBj",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "d3a7796e-c974-40b4-febd-ead0c5aaff1a"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "✅ Using FIXED ground truth from pre-authored AAR corpus:\n",
            "   Primary limiting factor: fuel resupply delay (12/25 AARs)\n",
            "   Dominant weather: sandstorm (11/25 AARs)\n",
            "   Top 2 logistics issues: ['fuel resupply delay', 'route closure at bridge']\n",
            "   BFT outage locations: AAR_07.txt, AAR_19.txt\n",
            "✅ Evaluation Harness Defined with LLM-as-Judge.\n"
          ]
        }
      ],
      "source": [
        "# --- Fixed Ground Truth (from pre-authored AAR corpus) ---\n",
        "primary_true_log = \"fuel resupply delay\"  # Appears in 12 of 25 AARs (48%)\n",
        "dominant_weather = \"sandstorm\"            # Appears in 11 of 25 AARs (44%)\n",
        "top_2_logs = [\"fuel resupply delay\", \"route closure at bridge\"]  # 12 and 5 instances respectively\n",
        "\n",
        "print(\"✅ Using FIXED ground truth from pre-authored AAR corpus:\")\n",
        "print(f\"   Primary limiting factor: {primary_true_log} (12/25 AARs)\")\n",
        "print(f\"   Dominant weather: {dominant_weather} (11/25 AARs)\")\n",
        "print(f\"   Top 2 logistics issues: {top_2_logs}\")\n",
        "print(f\"   BFT outage locations: AAR_07.txt, AAR_19.txt\")\n",
        "\n",
        "# --- Define Evaluation Questions ---\n",
        "EVAL_QUESTIONS = [\n",
        "    {\"id\":\"Q1 (Aggregate)\",\"question\":\"What was the primary limiting factor for Blue Force's logistics during the exercise?\",\n",
        "     \"expect_keywords_any\":[primary_true_log],\"min_citations\":2},\n",
        "    {\"id\":\"Q2 (Dominant)\",\"question\":\"Which weather condition most frequently degraded mobility?\",\n",
        "     \"expect_keywords_any\":[dominant_weather],\"min_citations\":2},\n",
        "    {\"id\":\"Q3 (Specific)\",\"question\":\"Did any unit report a Blue Force Tracker outage over 30 minutes? Provide details.\",\n",
        "     \"expect_keywords_any\":[\"BFT outage 45 min\"],\"min_citations\":1},\n",
        "    {\"id\":\"Q4 (Lesson)\",\"question\":\"Provide one actionable lesson learned for mobility and cite a source.\",\n",
        "     \"expect_keywords_any\":[\"Prioritize alternate MSR recon\"],\"min_citations\":1},\n",
        "    {\"id\":\"Q5 (Hallucination)\",\"question\":\"What was the primary casualty-producing weapon used by OPFOR?\",\n",
        "     \"expect_keywords_any\":[\"insufficient evidence\", \"not available\", \"not found\"],\"min_citations\":0},\n",
        "    {\"id\":\"Q6 (Synthesis)\",\"question\":\"What were the two most common logistics issues reported across the exercise?\",\n",
        "     \"expect_keywords_any\": top_2_logs, \"min_citations\": 3}\n",
        "]\n",
        "\n",
        "# --- Define LLM-as-Judge Function ---\n",
        "def llm_judge(answer_text, correct_answer, question_text):\n",
        "    \"\"\"\n",
        "    Use the LLM to judge if the generated answer contains the correct information.\n",
        "    Returns a score between 0 and 1.\n",
        "    \"\"\"\n",
        "    judge_prompt = f\"\"\"Question: {question_text}\n",
        "\n",
        "Expected Answer Key: {correct_answer}\n",
        "\n",
        "Generated Answer: {answer_text}\n",
        "\n",
        "Does the generated answer contain the key information from the expected answer?\n",
        "Answer with just a number between 0 and 1, where:\n",
        "- 1.0 = correct information is clearly present\n",
        "- 0.5 = partially correct or ambiguous\n",
        "- 0.0 = incorrect or missing information\n",
        "\n",
        "Score:\"\"\"\n",
        "\n",
        "    try:\n",
        "        # Use the GPU model if available\n",
        "        if pipe_gpu:\n",
        "            inputs = tokenizer_gpu(judge_prompt, return_tensors=\"pt\").to(DEVICE)\n",
        "            outputs = model_gpu.generate(\n",
        "                **inputs,\n",
        "                max_new_tokens=10,\n",
        "                temperature=0.1,\n",
        "                do_sample=True,\n",
        "                pad_token_id=tokenizer_gpu.eos_token_id\n",
        "            )\n",
        "            response = tokenizer_gpu.decode(outputs[0], skip_special_tokens=True)\n",
        "\n",
        "            # Extract the generated part (after the prompt)\n",
        "            if \"Score:\" in response:\n",
        "                score_part = response.split(\"Score:\")[-1].strip()\n",
        "            else:\n",
        "                score_part = response[len(judge_prompt):].strip()\n",
        "\n",
        "            # Extract first valid number (0.0 to 1.0)\n",
        "            import re\n",
        "            numbers = re.findall(r'\\b([0-1]\\.?\\d*)\\b', score_part)\n",
        "            if numbers:\n",
        "                score = float(numbers[0])\n",
        "                return max(0.0, min(1.0, score))\n",
        "            else:\n",
        "                raise ValueError(f\"No valid score found in: {score_part}\")\n",
        "\n",
        "        # Use the CPU model if available\n",
        "        elif pipe_cpu:\n",
        "            inputs = tokenizer_cpu(judge_prompt, return_tensors=\"pt\")\n",
        "            outputs = model_cpu.generate(\n",
        "                **inputs,\n",
        "                max_new_tokens=10,\n",
        "                temperature=0.1,\n",
        "                do_sample=True,\n",
        "                pad_token_id=tokenizer_cpu.eos_token_id\n",
        "            )\n",
        "            response = tokenizer_cpu.decode(outputs[0], skip_special_tokens=True)\n",
        "\n",
        "            # For seq2seq models, response is just the generation (no prompt)\n",
        "            import re\n",
        "            numbers = re.findall(r'\\b([0-1]\\.?\\d*)\\b', response)\n",
        "            if numbers:\n",
        "                score = float(numbers[0])\n",
        "                return max(0.0, min(1.0, score))\n",
        "            else:\n",
        "                raise ValueError(f\"No valid score found in: {response}\")\n",
        "\n",
        "        # No LLM available\n",
        "        else:\n",
        "            return 1.0 if correct_answer.lower() in answer_text.lower() else 0.0\n",
        "\n",
        "    except Exception as e:\n",
        "        print(f\"⚠️ LLM judge failed: {e}, falling back to string matching\")\n",
        "        return 1.0 if correct_answer.lower() in answer_text.lower() else 0.0\n",
        "\n",
        "# --- Define Scoring Function ---\n",
        "def score_answer(text: str, contexts: List[Dict], expect_keywords_any: List[str],\n",
        "                 min_citations: int, question: str = \"\") -> tuple:\n",
        "    \"\"\"\n",
        "    Score answer using LLM-as-judge for semantic coverage evaluation.\n",
        "\n",
        "    Args:\n",
        "        text: The generated answer\n",
        "        contexts: Retrieved context chunks\n",
        "        expect_keywords_any: Expected concepts (list)\n",
        "        min_citations: Minimum required citations\n",
        "        question: Original question (for LLM judge context)\n",
        "\n",
        "    Returns:\n",
        "        (coverage_score, citation_score, cited_docs, text)\n",
        "    \"\"\"\n",
        "    text_l = text.lower()\n",
        "\n",
        "    # --- COVERAGE SCORING ---\n",
        "\n",
        "    # Special case: Refusal test (Q5 - hallucination prevention)\n",
        "    if \"insufficient evidence\" in \" \".join(expect_keywords_any).lower():\n",
        "        refused = any(k.lower() in text_l for k in expect_keywords_any)\n",
        "        if refused:\n",
        "            coverage_score = 1.0\n",
        "            citation_score = 1.0 if len(re.findall(r\"AAR_\\d{2}\\.txt\", text)) == 0 else 0.0\n",
        "        else:\n",
        "            coverage_score = 0.0\n",
        "            citation_score = 0.0\n",
        "    else:\n",
        "        # Use LLM-as-judge for semantic coverage evaluation\n",
        "        if len(expect_keywords_any) > 1:\n",
        "            # Synthesis question - all concepts must be present\n",
        "            individual_scores = []\n",
        "            for keyword in expect_keywords_any:\n",
        "                score = llm_judge(text, keyword, question)\n",
        "                individual_scores.append(score)\n",
        "                print(f\"    → LLM Judge: '{keyword}' = {score}\")\n",
        "            coverage_score = float(all(s > 0.5 for s in individual_scores))\n",
        "        else:\n",
        "            # Single concept question\n",
        "            coverage_score = llm_judge(text, expect_keywords_any[0], question)\n",
        "            print(f\"    → LLM Judge: '{expect_keywords_any[0]}' = {coverage_score}\")\n",
        "\n",
        "    # --- CITATION SCORING ---\n",
        "\n",
        "    citations = re.findall(r\"AAR_\\d{2}\\.txt\", text, re.IGNORECASE)\n",
        "    cited_docs = list(set(citations))\n",
        "\n",
        "    # Fallback if model forgot to cite\n",
        "    if not cited_docs and \"insufficient\" not in text_l:\n",
        "        cited_docs = sorted(list({c['doc'] for c in contexts}))\n",
        "\n",
        "    citation_score = float(len(cited_docs) >= min_citations)\n",
        "\n",
        "    return coverage_score, citation_score, cited_docs, text\n",
        "\n",
        "print(\"✅ Evaluation Harness Defined with LLM-as-Judge.\")"
      ]
    },
